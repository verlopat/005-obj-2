# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=security-events
KAFKA_TOPIC_DLQ=security-events-dlq
KAFKA_CONSUMER_GROUP=blockchain-logger-group

# ── Hyperledger Fabric ─────────────────────────────────────────────────────────
FABRIC_GATEWAY_HOST=localhost
FABRIC_GATEWAY_PORT=7051
FABRIC_CHANNEL_NAME=security-channel
FABRIC_CHAINCODE_NAME=security_logger
FABRIC_MSP_ID=Org1MSP
FABRIC_CERT_PATH=/certs/signcerts/cert.pem
FABRIC_KEY_PATH=/certs/keystore/key.pem
FABRIC_TLS_CERT_PATH=/certs/tls/ca.crt

# ── IPFS ───────────────────────────────────────────────────────────────────────
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# ── Services ───────────────────────────────────────────────────────────────────
AUDIT_API_URL=http://audit-api:8001
REPORTS_OUTPUT_DIR=/app/reports

# ── Signing (ECDSA P-256) ──────────────────────────────────────────────────────
SIGNING_KEY_PATH=/certs/signing/private_key.pem
SIGNING_CERT_PATH=/certs/signing/cert.pem

# ── Compliance Scheduler ───────────────────────────────────────────────────────
COMPLIANCE_STANDARDS=ISO-27001,SOC-2,NIST-SP-800-92
SCHEDULE_DAILY_HOUR=2
SCHEDULE_WEEKLY_DAY=monday

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
