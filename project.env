# ============================================================
# project.env  —  local dev defaults for Docker Compose stack
# Generated / maintained by setup_env.sh
# Safe to commit: all values point to localhost Docker containers
# or local fabric-samples paths (no secrets).
# ============================================================

# ----- Fabric binaries (fabric-samples/bin) -----
FABRIC_BIN_DIR=/home/varamm/Personal/d-study/Papers/pakkodivi/Progress/005_phd/code/005-obj-2/fabric-samples/bin
FABRIC_CFG_PATH=/home/varamm/Personal/d-study/Papers/pakkodivi/Progress/005_phd/code/005-obj-2/fabric-samples/config

# ----- Kafka (Bitnami Kafka, single-broker) -----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_EVENTS_TOPIC=security-events
KAFKA_GROUP_ID=blockchain-logger-group

# ----- IPFS (go-ipfs node in Docker) -----
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# ----- Redis (dedup / idempotency cache) -----
REDIS_URL=redis://localhost:6379/0

# ----- Hyperledger Fabric -----
FABRIC_MSP_ID=Org1MSP
FABRIC_CHANNEL=security-channel
FABRIC_CC_NAME=security_logger

# These three point into crypto-config/ which run.py generates in Step 2.
FABRIC_TLS_CERT=crypto-config/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt
FABRIC_SIGN_CERT=crypto-config/agent/signcerts/agent.pem
FABRIC_SIGN_KEY=crypto-config/agent/keystore/agent_sk

FABRIC_PEER_ADDRESS=peer0.org1.example.com:7051
FABRIC_ORDERER_ADDRESS=orderer.example.com:7050

# ----- Service URLs (used by run.py benchmark) -----
DETECTOR_URL=http://localhost:8000
AUDIT_URL=http://localhost:8001

# ----- Detector Adapter -----
DETECTOR_HOST=0.0.0.0
DETECTOR_PORT=8000
DETECTOR_LOG_LEVEL=INFO

# ----- Audit API -----
AUDIT_HOST=0.0.0.0
AUDIT_PORT=8001
AUDIT_LOG_LEVEL=INFO

# ----- Observability -----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
