# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Do NOT ignore project.env — it ships with safe defaults
# project.env   <-- intentionally NOT gitignored
.env
.env.local
.env.*.local

# ── Fabric / crypto ───────────────────────────────────────
crypto-config/
channel-artifacts/
*.block
*.tx
fabric-config/

# ── Secrets ───────────────────────────────────────────────
*.pem
*.key
*_sk
# secret.key is already in history; keep this rule so it is
# never re-added after git filter-repo removes it
secret.key

# ── Build artefacts ───────────────────────────────────────
*.tar.gz
security_logger.tar.gz

# ── Runtime / logs ────────────────────────────────────────
results/*.log

# ── IDE / OS ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker volumes (if bind-mounted) ──────────────────────
volumes/

# ── Activate script (generated by setup_env.sh) ───────────
activate_project.sh
